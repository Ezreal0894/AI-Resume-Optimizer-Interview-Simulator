// ============================================
// Prisma Schema - AI Career Platform
// 🔄 v2.0 重构版本：完整契约对齐
// - 雷达图 5 维度：technical, communication, problemSolving, cultureFit, leadership
// - 简历分析：ATS 高阶结构
// - 文档库：isPinned 聚合查询支持
// - 积分补偿事务
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户模型
// ============================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String?
  avatar       String?
  
  // Onboarding 标签（最多 10 个）
  tags         String[] @default([])
  
  // 会员与积分
  plan         UserPlan @default(FREE)
  planExpireAt DateTime?
  credits      Int      @default(50)
  
  // 时间戳
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // 关联
  resumes           Resume[]
  interviewSessions InterviewSession[]
  
  // Token 管理
  refreshTokenHash  String?
  
  @@map("users")
}

enum UserPlan {
  FREE
  PRO
  ENTERPRISE
}

// ============================================
// 简历模型
// 🔄 新增：isPinned, 高阶 analysisReport 结构
// analysisReport JSON 结构：
// {
//   "overallScore": 85,
//   "atsCompatibility": { "score": 90, "suggestions": ["..."] },
//   "keywordAnalysis": { "matched": ["React"], "missing": ["AWS"] },
//   "structureAnalysis": { "sections": ["Experience"], "improvements": ["..."] },
//   "contentSuggestions": ["量化成果", "添加指标"]
// }
// ============================================
model Resume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 文件元信息
  fileName      String
  fileSize      Int
  mimeType      String
  rawContent    String   @db.Text
  
  // JD 对标
  targetRole    String?
  targetJd      String?  @db.Text
  
  // AI 分析报告（高阶 ATS 结构）
  analysisReport Json?   @db.JsonB
  
  // 状态与置顶
  status    ResumeStatus @default(PENDING)
  isPinned  Boolean      @default(false)
  
  // 时间戳
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@index([userId, createdAt])
  @@map("resumes")
}

enum ResumeStatus {
  PENDING
  ANALYZING
  COMPLETED
  FAILED
}

// ============================================
// 面试会话模型
// 🔄 新增：isPinned
// metrics JSON 结构：
// {
//   "overallScore": 88,
//   "radar": {
//     "technical": 85,
//     "communication": 90,
//     "problemSolving": 88,
//     "cultureFit": 82,
//     "leadership": 75
//   },
//   "feedback": {
//     "strengths": ["..."],
//     "improvements": ["..."]
//   }
// }
// ============================================
model InterviewSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 面试配置
  jobTitle       String
  jobDescription String?
  difficulty     InterviewDifficulty @default(MEDIUM)
  
  // 状态与置顶
  status    InterviewStatus @default(IN_PROGRESS)
  isPinned  Boolean         @default(false)
  
  // AI 分析报告
  metrics   Json?    @db.JsonB
  
  // 时间戳
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 对话记录
  messages  InterviewMessage[]
  
  @@index([userId])
  @@index([userId, createdAt])
  @@map("interview_sessions")
}

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// 面试消息模型
// ============================================
model InterviewMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role      MessageRole
  content   String      @db.Text
  
  createdAt DateTime @default(now())
  
  @@index([sessionId])
  @@map("interview_messages")
}

enum MessageRole {
  SYSTEM
  ASSISTANT
  USER
}
