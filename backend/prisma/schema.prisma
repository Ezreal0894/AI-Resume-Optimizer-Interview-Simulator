// ============================================
// Prisma Schema - AI Career Platform
// 数据库设计：PostgreSQL + JSONB 灵活存储
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户模型 - 存储用户基本信息与认证数据
// ============================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String   // bcrypt 加密存储
  name         String?
  avatar       String?
  
  // 会员相关
  plan         UserPlan @default(FREE)
  planExpireAt DateTime?
  
  // 时间戳
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // 关联关系
  resumes           Resume[]
  interviewSessions InterviewSession[]
  
  // Refresh Token 存储（用于 Token 轮换和撤销）
  refreshTokenHash  String?
  
  @@map("users")
}

enum UserPlan {
  FREE
  PRO
  ENTERPRISE
}

// ============================================
// 简历模型 - 存储简历文件信息与 AI 分析结果
// ============================================
model Resume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 文件元信息（不存储文件本身，仅存储解析后的数据）
  fileName      String
  fileSize      Int
  mimeType      String
  
  // 解析后的原始文本内容
  rawContent    String   @db.Text
  
  // AI 分析报告 - 使用 JSONB 灵活存储
  // 结构示例: {
  //   "overallScore": 85,
  //   "atsCompatibility": { "score": 90, "suggestions": [...] },
  //   "keywordAnalysis": { "matched": [...], "missing": [...] },
  //   "structureAnalysis": { "sections": [...], "improvements": [...] },
  //   "contentSuggestions": [...],
  //   "optimizedVersion": "..."
  // }
  analysisReport Json?    @db.JsonB
  
  // 状态
  status    ResumeStatus @default(PENDING)
  
  // 时间戳
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@map("resumes")
}

enum ResumeStatus {
  PENDING    // 待分析
  ANALYZING  // 分析中
  COMPLETED  // 已完成
  FAILED     // 分析失败
}

// ============================================
// 面试会话模型 - 记录一次完整的模拟面试
// ============================================
model InterviewSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 面试配置
  jobTitle      String           // 目标岗位
  jobDescription String?         // 岗位描述
  difficulty    InterviewDifficulty @default(MEDIUM)
  
  // 面试状态
  status    InterviewStatus @default(IN_PROGRESS)
  
  // 面试结束后的多维度分析报告 - 使用 JSONB 灵活存储
  // 结构示例: {
  //   "overallScore": 88,
  //   "dimensions": {
  //     "technicalDepth": 85,
  //     "communication": 90,
  //     "logicalThinking": 88,
  //     "projectExperience": 82,
  //     "stressResistance": 92
  //   },
  //   "strengths": [...],
  //   "improvements": [...],
  //   "detailedFeedback": "..."
  // }
  metrics   Json?    @db.JsonB
  
  // 时间戳
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 关联的对话记录
  messages  InterviewMessage[]
  
  @@index([userId])
  @@map("interview_sessions")
}

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum InterviewStatus {
  IN_PROGRESS  // 进行中
  COMPLETED    // 已完成
  CANCELLED    // 已取消
}

// ============================================
// 面试消息模型 - 记录单条对话
// ============================================
model InterviewMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // 消息内容
  role      MessageRole
  content   String      @db.Text
  
  // 时间戳
  createdAt DateTime @default(now())
  
  @@index([sessionId])
  @@map("interview_messages")
}

enum MessageRole {
  SYSTEM      // 系统提示词
  ASSISTANT   // AI 面试官
  USER        // 用户
}
